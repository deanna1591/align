# Copy to .env and fill in values.

# Your Supabase project URL (same as the main app).
SUPABASE_URL=https://your-project-id.supabase.co

# Service role key — Settings > API > service_role.
# DO NOT commit this. Treat it like a password.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# The email address you signed up with in the Align app.
ALIGN_USER_EMAIL=you@example.com

# (Optional) Folder name on the reMarkable. Default: Align
REMARKABLE_FOLDER=Align
